{
  "functions": {
    "api/index.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/complete_index.html"
    }
  ],
  "env": {
    "DATABASE_URL": "sqlite+aiosqlite:////tmp/roommate.db",
    "SECRET_KEY": "your-production-secret-key-change-this",
    "ALGORITHM": "HS256"
  }
}
